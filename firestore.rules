rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/config/settings) &&
        request.auth.uid in get(/databases/$(database)/documents/config/settings).data.adminUIDs;
    }

    function isGroupAdmin(groupId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/groups/$(groupId)) &&
        request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.adminUIDs;
    }

    // Reading a map field that doesn't exist with dot-notation throws in
    // Firestore rules (even when wrapped in `!= true`), so check for the
    // key with `in` first. This treats accounts created before the champion
    // feature existed (no `championPicksLocked` field yet) as "not locked".
    function championPicksLocked() {
      let cfg = get(/databases/$(database)/documents/config/settings).data;
      return ('championPicksLocked' in cfg) && cfg.championPicksLocked == true;
    }

    // ---- /config/settings ----
    // Everyone signed in can read the config (prize pool, distribution, admin list).
    // The very first authenticated user may CREATE /config/settings (bootstrapping
    // themselves as admin via adminUIDs). After it exists, only admins can update it.
    match /config/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && !exists(/databases/$(database)/documents/config/settings);
      allow update, delete: if isAdmin();
    }

    // ---- /matches/{matchId} ----
    // Everyone signed in can read matches. Only admins can create/edit matches
    // or enter official results.
    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---- /users/{uid} ----
    // Everyone signed in can read the users collection (for the leaderboard).
    // A user can only write their own profile document. Admins may also write
    // user documents so totalPoints can be recalculated after results are entered.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if false;
    }

    // ---- /championPicks/{uid} ----
    // Everyone signed in can read all picks (for transparency once locked).
    // A user may create/update only their own pick, and only while picks
    // aren't locked. Admins can write any pick to record bonus points once
    // the real champion is set.
    match /championPicks/{uid} {
      allow read: if isSignedIn();

      allow create, update: if isSignedIn() && request.auth.uid == uid && !championPicksLocked();

      allow write: if isAdmin();

      allow delete: if false;
    }

    // ---- /predictions/{uid}_{matchId} ----
    // Everyone signed in can read all predictions (for "My Predictions" / stats).
    // A user may create/update only their own prediction (docId must start with
    // their own uid) and only while the referenced match is not locked.
    // Admins may write any prediction so points can be recalculated once a
    // match result is entered.
    match /predictions/{docId} {
      allow read: if isSignedIn();

      allow create, update: if isSignedIn() &&
        docId.split('_')[0] == request.auth.uid &&
        request.resource.data.uid == request.auth.uid &&
        !get(/databases/$(database)/documents/matches/$(request.resource.data.matchId)).data.locked;

      allow write: if isAdmin();

      allow delete: if false;
    }

    // ---- /groups/{groupId}/members/{uid} (collection group) ----
    // Nested `match` blocks don't apply to collectionGroup() queries, so all
    // rules for member docs live in this single top-level rule (using the
    // {path=**} wildcard), which also covers normal /groups/{id}/members/{uid}
    // reads/writes. `path` here is everything before "/members/{uid}", i.e.
    // ['groups', groupId], so path[1] is the groupId.
    //
    // Any signed-in user can read membership docs (needed to list a group's
    // members and to query "my memberships" across groups). A user can join
    // a group themselves (status 'approved') as long as they prove they have
    // the group's current invite code; this also covers re-joining after a
    // leftover 'pending' doc from before this feature. Group admins can
    // create/edit any member doc directly (no code needed). A user can
    // remove their own membership (leave) and group admins can remove any
    // member.
    match /{path=**}/members/{uid} {
      allow read: if isSignedIn();

      function hasValidInviteCode() {
        return request.resource.data.inviteCode ==
          get(/databases/$(database)/documents/groups/$(path[1])).data.inviteCode;
      }

      function isSelfJoinWithCode() {
        return request.auth.uid == uid &&
          request.resource.data.uid == uid &&
          request.resource.data.status == 'approved' &&
          hasValidInviteCode();
      }

      allow create: if isSignedIn() && (isSelfJoinWithCode() || isGroupAdmin(path[1]));

      allow update: if isSignedIn() && (isSelfJoinWithCode() || isGroupAdmin(path[1]));

      allow delete: if isSignedIn() && (request.auth.uid == uid || isGroupAdmin(path[1]));
    }

    // ---- /groups/{groupId} ----
    // Any signed-in user can read groups (needed to resolve invite links)
    // and create a new group, becoming its sole owner/admin. Only the
    // group's admins can edit it (name, prize pool, distribution, bonus,
    // invite code, adminUIDs).
    match /groups/{groupId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.adminUIDs == [request.auth.uid];

      allow update: if isGroupAdmin(groupId);
      allow delete: if false;
    }
  }
}
